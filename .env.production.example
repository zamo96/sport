NODE_ENV=production
PORT=3002
APP_PORT=3002
APPLE_IOS_BUNDLE_ID=shop.sportsearch.app

POSTGRES_DB=tennis_search
POSTGRES_USER=tennis
POSTGRES_PASSWORD=change_me_to_a_long_random_password
DATABASE_URL=postgresql://tennis:change_me_to_a_long_random_password@db:5432/tennis_search?schema=public

NEXT_PUBLIC_MAP_PROVIDER=yandex
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=

EMAIL_PROVIDER=smtp
EMAIL_FROM=TennisSearch <no-reply@example.ru>
SMTP_HOST=postbox.cloud.yandex.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=change_me_to_yandex_postbox_api_key_id
SMTP_PASSWORD=change_me_to_yandex_postbox_api_key_secret

UPLOADS_PROVIDER=s3
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_BUCKET=change_me_to_yandex_object_storage_bucket
S3_ACCESS_KEY_ID=change_me_to_yandex_object_storage_static_key_id
S3_SECRET_ACCESS_KEY=change_me_to_yandex_object_storage_static_key_secret
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=https://storage.yandexcloud.net/change_me_to_yandex_object_storage_bucket

# Optional. If empty, seed will try docs/import/clubs.xlsx.
CLUBS_IMPORT_FILE=
