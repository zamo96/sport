generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  male
  female
  other
}

enum Sport {
  table_tennis
  tennis
  padel
  squash
  badminton
  volleyball
  fitness
  boxing
  yoga
  football
}

enum PlayFormat {
  singles
  doubles
  both
}

enum Surface {
  hard
  clay
  grass
  any
}

enum CourtSetting {
  indoor
  outdoor
}

enum SwipeAction {
  like
  dislike
  superlike
}

enum MatchStatus {
  active
  archived
}

enum GameRequestStatus {
  pending
  accepted
  declined
  canceled
}

enum GameRequestOutcome {
  played
  not_played
}

enum GameSearchStatus {
  active
  in_review
  matched
  closed
}

enum GameSearchType {
  regular
  hot
}

enum HotSearchWindow {
  today
  tomorrow
  day_after_tomorrow
}

enum GameSearchResponseStatus {
  pending
  approved
  rejected
  withdrawn
}

enum GameSearchSlotProposalStatus {
  open
  closed
}

enum RegularPairStatus {
  active
  paused
  closed
}

enum RegularPairOccurrenceStatus {
  pending
  confirmed
  declined
  canceled
  expired
}

enum RegularPairOccurrenceConfirmationStatus {
  pending
  confirmed
  declined
}

enum PushPlatform {
  ios
}

enum PushEnvironment {
  development
  production
}

model District {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  city        String
  color       String?
  centerLat   Float?
  centerLng   Float?
  polygon     Json?
  searchHints Json?
  users       User[]  @relation("UserDistrict")
  courts      Court[] @relation("CourtDistrict")

  @@index([city, name])
}

model Metro {
  id        String  @id @default(cuid())
  name      String  @unique
  city      String
  courts    Court[] @relation("CourtNearestMetro")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([city, name])
}

model User {
  id                   String        @id @default(cuid())
  email                String        @unique
  appleSubject         String?       @unique
  name                 String?
  age                  Int?
  gender               Gender?
  city                 String?
  district             String?
  preferredDistricts   Json?
  homeLat              Float?
  homeLng              Float?
  tennisLevel          Int?
  preferredSports      Json?
  sportLevels          Json?
  preferredPlayFormat  PlayFormat    @default(both)
  preferredSurface     Surface       @default(any)
  bio                  String?
  avatarUrl            String?
  searchRadiusKm       Int           @default(20)
  availableDays        Json?
  availableTimeRanges  Json?
  availableTimeSlots   Json?
  availabilityByDay    Json?
  isLookingForGame     Boolean       @default(true)
  isVerified           Boolean       @default(false)
  onboardingCompleted  Boolean       @default(false)
  notificationMatches  Boolean       @default(true)
  notificationMessages Boolean       @default(true)
  notificationGames    Boolean       @default(true)
  notificationSound    Boolean       @default(true)
  lastInboxSeenAt      DateTime?
  lastNotificationsSeenAt DateTime?
  lastActiveAt         DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  districtRef          District?     @relation("UserDistrict", fields: [district], references: [code], onDelete: SetNull)
  swipesSent           Swipe[]       @relation("SwipeFromUser")
  swipesReceived       Swipe[]       @relation("SwipeToUser")
  matchesAsUser1       Match[]       @relation("MatchUser1")
  matchesAsUser2       Match[]       @relation("MatchUser2")
  sessions             Session[]
  authCodes            AuthCode[]
  sentMessages         ChatMessage[]
  gameRequestsCreated  GameRequest[] @relation("GameRequestCreator")
  gameRequestsReceived GameRequest[] @relation("GameRequestRecipient")
  gameSearches         GameSearch[]
  gameSearchMessages   GameSearchMessage[]
  gameSearchResponses  GameSearchResponse[]
  gameSearchSlotVotes  GameSearchSlotVote[]
  regularPairsCreated  RegularPair[] @relation("RegularPairCreator")
  regularPairsPartner  RegularPair[] @relation("RegularPairPartner")
  regularPairOccurrenceConfirmations RegularPairOccurrenceConfirmation[]
  pushDevices          PushDevice[]
  blockedUsers         Block[]       @relation("BlockerUser")
  blockingUsers        Block[]       @relation("BlockedUser")
}

model Court {
  id              String        @id @default(cuid())
  name            String
  address         String
  city            String
  district        String?
  nearestMetroId  String?
  locationLat     Float
  locationLng     Float
  surface         Surface
  setting         CourtSetting
  supportedSports Json?
  phone           String?
  workingHours    String?
  yandexMapsUrl   String?
  websiteUrl      String?
  photoUrl        String?
  priceRange      String
  rating          Float?
  sourceType      String
  bookingUrl      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  districtRef     District?     @relation("CourtDistrict", fields: [district], references: [code], onDelete: SetNull)
  nearestMetro    Metro?        @relation("CourtNearestMetro", fields: [nearestMetroId], references: [id], onDelete: SetNull)
  gameRequests    GameRequest[]
  gameSearches    GameSearch[]
  scheduledGameSearches GameSearch[] @relation("GameSearchScheduledCourt")
  gameSearchSlotOptions GameSearchSlotOption[]
  regularPairs    RegularPair[]
  regularPairOccurrences RegularPairOccurrence[]

  @@index([district])
  @@index([nearestMetroId])
}

model Swipe {
  id         String      @id @default(cuid())
  fromUserId String
  toUserId   String
  action     SwipeAction
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  fromUser   User        @relation("SwipeFromUser", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser     User        @relation("SwipeToUser", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([toUserId, action])
}

model Match {
  id           String        @id @default(cuid())
  user1Id      String
  user2Id      String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  status       MatchStatus   @default(active)
  user1        User          @relation("MatchUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2        User          @relation("MatchUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  messages     ChatMessage[]
  gameRequests GameRequest[]
  regularPairs RegularPair[]

  @@unique([user1Id, user2Id])
  @@index([user1Id, updatedAt])
  @@index([user2Id, updatedAt])
}

model GameRequest {
  id               String            @id @default(cuid())
  matchId          String
  sharedRootId     String?
  regularPairOccurrenceId String?    @unique
  createdByUserId  String
  matchedUserId    String
  proposedCourtId  String
  proposedDatetime DateTime
  durationMinutes  Int?
  levelRangeMin    Int?
  levelRangeMax    Int?
  sport            Sport             @default(tennis)
  format           PlayFormat
  comment          String?
  status           GameRequestStatus @default(pending)
  outcome          GameRequestOutcome?
  outcomeUpdatedAt DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  match            Match             @relation(fields: [matchId], references: [id], onDelete: Cascade)
  sharedRoot       GameRequest?      @relation("GameRequestShareRoot", fields: [sharedRootId], references: [id], onDelete: SetNull)
  sharedInvites    GameRequest[]     @relation("GameRequestShareRoot")
  regularPairOccurrence RegularPairOccurrence? @relation(fields: [regularPairOccurrenceId], references: [id], onDelete: SetNull)
  createdByUser    User              @relation("GameRequestCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  matchedUser      User              @relation("GameRequestRecipient", fields: [matchedUserId], references: [id], onDelete: Cascade)
  proposedCourt    Court             @relation(fields: [proposedCourtId], references: [id], onDelete: Restrict)
  messages         ChatMessage[]

  @@index([matchedUserId, status])
  @@index([createdByUserId, status])
  @@index([sharedRootId, status])
}

model ChatMessage {
  id            String       @id @default(cuid())
  matchId       String
  gameRequestId String?
  senderUserId  String
  text          String
  createdAt     DateTime     @default(now())
  match         Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  gameRequest   GameRequest? @relation(fields: [gameRequestId], references: [id], onDelete: Cascade)
  senderUser    User         @relation(fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([matchId, createdAt])
  @@index([gameRequestId, createdAt])
}

model GameSearch {
  id                  String               @id @default(cuid())
  inviteSlug          String?              @unique
  createdByUserId     String
  preferredCourtId    String?
  preferredDistricts  Json?
  scheduledCourtId    String?
  preferredDays       Json
  preferredTimeRanges Json
  searchType          GameSearchType       @default(regular)
  hotWindow           HotSearchWindow?
  hotStartsAt         DateTime?
  durationMinutes     Int?
  scheduledAt         DateTime?
  scheduledDurationMinutes Int?
  hasCourtBooked      Boolean              @default(false)
  sport               Sport                @default(tennis)
  selfLevel           Int?
  selfLevelUnknown    Boolean              @default(false)
  desiredLevelMin     Int                  @default(1)
  desiredLevelMax     Int                  @default(10)
  format              PlayFormat
  playersNeeded       Int                  @default(1)
  comment             String?
  status              GameSearchStatus     @default(active)
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  createdByUser       User                 @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  preferredCourt      Court?               @relation(fields: [preferredCourtId], references: [id], onDelete: SetNull)
  scheduledCourt      Court?               @relation("GameSearchScheduledCourt", fields: [scheduledCourtId], references: [id], onDelete: SetNull)
  responses           GameSearchResponse[]
  regularPair         RegularPair?
  messages            GameSearchMessage[]
  slotProposals       GameSearchSlotProposal[]

  @@index([createdByUserId, isActive])
  @@index([isActive, searchType, status])
}

model GameSearchResponse {
  id              String                   @id @default(cuid())
  gameSearchId    String
  responderUserId String
  message         String?
  status          GameSearchResponseStatus @default(pending)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  gameSearch      GameSearch               @relation(fields: [gameSearchId], references: [id], onDelete: Cascade)
  responderUser   User                     @relation(fields: [responderUserId], references: [id], onDelete: Cascade)

  @@unique([gameSearchId, responderUserId])
  @@index([gameSearchId, status])
  @@index([responderUserId, status])
}

model GameSearchMessage {
  id            String     @id @default(cuid())
  gameSearchId  String
  senderUserId  String
  text          String
  createdAt     DateTime   @default(now())
  gameSearch    GameSearch @relation(fields: [gameSearchId], references: [id], onDelete: Cascade)
  senderUser    User       @relation(fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([gameSearchId, createdAt])
}

model GameSearchSlotProposal {
  id           String                       @id @default(cuid())
  gameSearchId String
  comment      String?
  status       GameSearchSlotProposalStatus @default(open)
  createdAt    DateTime                     @default(now())
  updatedAt    DateTime                     @updatedAt
  gameSearch   GameSearch                   @relation(fields: [gameSearchId], references: [id], onDelete: Cascade)
  options      GameSearchSlotOption[]

  @@index([gameSearchId, status, createdAt])
}

model GameSearchSlotOption {
  id             String                @id @default(cuid())
  proposalId     String
  proposedCourtId String?
  scheduledAt    DateTime
  durationMinutes Int?
  createdAt      DateTime              @default(now())
  proposal       GameSearchSlotProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  proposedCourt  Court?                @relation(fields: [proposedCourtId], references: [id], onDelete: SetNull)
  votes          GameSearchSlotVote[]

  @@index([proposalId, scheduledAt])
}

model GameSearchSlotVote {
  id        String               @id @default(cuid())
  optionId  String
  userId    String
  createdAt DateTime             @default(now())
  option    GameSearchSlotOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([optionId, userId])
  @@index([userId, createdAt])
}

model RegularPair {
  id                  String            @id @default(cuid())
  gameSearchId        String            @unique
  matchId             String
  createdByUserId     String
  partnerUserId       String
  preferredCourtId    String?
  sport               Sport             @default(tennis)
  format              PlayFormat
  preferredDays       Json
  preferredTimeRanges Json
  comment             String?
  status              RegularPairStatus @default(active)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  gameSearch          GameSearch        @relation(fields: [gameSearchId], references: [id], onDelete: Cascade)
  match               Match             @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdByUser       User              @relation("RegularPairCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  partnerUser         User              @relation("RegularPairPartner", fields: [partnerUserId], references: [id], onDelete: Cascade)
  preferredCourt      Court?            @relation(fields: [preferredCourtId], references: [id], onDelete: SetNull)
  occurrences         RegularPairOccurrence[]

  @@index([createdByUserId, status])
  @@index([partnerUserId, status])
  @@index([matchId])
}

model RegularPairOccurrence {
  id                  String                            @id @default(cuid())
  regularPairId       String
  scheduledAt         DateTime
  scheduleAnchor      DateTime?
  durationMinutes     Int?
  proposedCourtId     String?
  sport               Sport                             @default(tennis)
  format              PlayFormat
  status              RegularPairOccurrenceStatus       @default(pending)
  createdAt           DateTime                          @default(now())
  updatedAt           DateTime                          @updatedAt
  regularPair         RegularPair                       @relation(fields: [regularPairId], references: [id], onDelete: Cascade)
  proposedCourt       Court?                            @relation(fields: [proposedCourtId], references: [id], onDelete: SetNull)
  confirmations       RegularPairOccurrenceConfirmation[]
  gameRequest         GameRequest?

  @@unique([regularPairId, scheduledAt])
  @@index([regularPairId, status, scheduledAt])
}

model RegularPairOccurrenceConfirmation {
  id            String                                  @id @default(cuid())
  occurrenceId  String
  userId        String
  status        RegularPairOccurrenceConfirmationStatus @default(pending)
  respondedAt   DateTime?
  createdAt     DateTime                                @default(now())
  updatedAt     DateTime                                @updatedAt
  occurrence    RegularPairOccurrence                   @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  user          User                                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([occurrenceId, userId])
  @@index([userId, status])
}

model Block {
  id            String   @id @default(cuid())
  blockerUserId String
  blockedUserId String
  createdAt     DateTime @default(now())
  blockerUser   User     @relation("BlockerUser", fields: [blockerUserId], references: [id], onDelete: Cascade)
  blockedUser   User     @relation("BlockedUser", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([blockerUserId, blockedUserId])
  @@index([blockedUserId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model AuthCode {
  id         String    @id @default(cuid())
  email      String
  code       String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email, createdAt])
}

model PushDevice {
  id               String          @id @default(cuid())
  userId           String
  platform         PushPlatform    @default(ios)
  environment      PushEnvironment @default(development)
  token            String          @unique
  bundleId         String
  deviceName       String?
  isActive         Boolean         @default(true)
  lastRegisteredAt DateTime        @default(now())
  lastDeliveredAt  DateTime?
  lastFailureAt    DateTime?
  lastFailureReason String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, platform, isActive])
  @@index([environment, isActive])
}
