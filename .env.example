DATABASE_URL="postgresql://tennis:tennis@localhost:5432/tennis_search?schema=public"
NODE_ENV="development"
APPLE_IOS_BUNDLE_ID="shop.sportsearch.app"
NEXT_PUBLIC_MAP_PROVIDER="yandex"
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=""
# Email delivery. Use console locally, smtp in production.
EMAIL_PROVIDER="console"
EMAIL_FROM=""
SMTP_HOST="postbox.cloud.yandex.net"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
# Avatar uploads. Use local for development, s3 for production.
UPLOADS_PROVIDER="local"
S3_ENDPOINT="https://storage.yandexcloud.net"
S3_REGION="ru-central1"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_FORCE_PATH_STYLE="true"
S3_PUBLIC_BASE_URL=""
# Optional. If empty, seed will try docs/import/clubs.xlsx
CLUBS_IMPORT_FILE=""
